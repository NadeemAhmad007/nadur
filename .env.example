# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# S3 / R2 (compatible with S3 SDK)
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=your-s3-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret
S3_BUCKET=your-bucket

# NextAuth
AUTH_SECRET=your-auth-secret-min-32-chars
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Resend (email)
RESEND_API_KEY=re_example_key

# Cloudinary (image optimization)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OpenWA (self-hosted WhatsApp API gateway)
OPENWA_API_URL=http://localhost:2785/api
OPENWA_API_KEY=your-openwa-api-key
OPENWA_SESSION=nadur-bot

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
