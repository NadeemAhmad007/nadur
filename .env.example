# Neon PostgreSQL
DATABASE_URL=postgresql://...

# S3 / R2 (compatible with S3 SDK)
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# NextAuth
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (email OTP delivery)
# Free tier: 100 emails/day from onboarding@resend.dev
# Sign up at https://resend.com
RESEND_API_KEY=

# Cloudinary (image optimization)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenWA (self-hosted WhatsApp API gateway — https://github.com/rmyndharis/OpenWA)
# Run: docker compose up -d (see docker-compose.yml)
OPENWA_API_URL=http://openwa:2785/api
OPENWA_API_KEY=change-me-to-a-random-secret
OPENWA_SESSION=nadur-bot

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
